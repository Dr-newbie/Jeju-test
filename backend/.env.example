NAVER_MAP_CLIENT_ID=your_ncp_maps_client_id
NAVER_MAP_CLIENT_SECRET=your_ncp_maps_client_secret

NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id
NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret

# comma-separated list of origins allowed to call this API (production frontend domain, etc.)
ALLOWED_ORIGINS=http://localhost:3000

# optional: defaults to a local sqlite file (backend/dev.db) if unset.
# set to a Postgres connection string in production so shared routes persist.
DATABASE_URL=
